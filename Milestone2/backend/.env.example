# Backend FastAPI Configuration
PORT=8501
HOST=0.0.0.0

# Memory Optimization (set to 'true' to enable features)
# Set to 'false' for lower memory usage on deployment
USE_BM25=false
USE_RERANKER=false

# LLM API Keys (required for RAG functionality)
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Data Paths (relative to backend directory)
# These will be resolved relative to the backend directory
DATA_PATH=../data
INDEXED_DATA_PATH=../data/indexed
PROCESSED_DATA_PATH=../data/processed

# Logging Configuration
LOG_LEVEL=INFO

# CORS (required for Vercel / local Next.js)
# Comma-separated origins, or * for local+Vercel regex defaults
CORS_ALLOW_ORIGINS=*
# Optional: override Vercel preview regex (default matches *.vercel.app)
# CORS_ALLOW_ORIGIN_REGEX=https://([a-z0-9-]+\.)*vercel\.app
# CORS_ALLOW_CREDENTIALS=false

# Environment
ENVIRONMENT=production
