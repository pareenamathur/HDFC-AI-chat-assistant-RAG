# Public API base (Railway FastAPI). HTTPS, no trailing slash.
# Required on Vercel production builds — without it the client falls back to 127.0.0.1 and queries will fail.
NEXT_PUBLIC_API_URL=https://your-app.up.railway.app

# Optional client timeout in ms (default 90000).
# NEXT_PUBLIC_API_TIMEOUT_MS=90000

# On Railway (FastAPI), set CORS_ALLOW_ORIGINS to your Vercel origin, e.g.:
#   CORS_ALLOW_ORIGINS=https://your-app.vercel.app
# or comma-separated list. Use * only for temporary debugging.
